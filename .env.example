# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (for embeddings via openai/text-embedding-3-small)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Atomic Coding Pixel

# Pixel 2D sprite service + background removal
FAL_API_KEY=
PIXEL_SPRITE_SERVICE_URL=https://your-sprite-service.example.com
PIXEL_SPRITE_SERVICE_KEY=
PIXEL_SPRITE_SERVICE_TIMEOUT_MS=120000

# Upstash Redis (caching + rate limiting in Edge Functions)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash (reliable job delivery)
QSTASH_TOKEN=

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Axiom (structured logging, optional)
AXIOM_INGEST_URL=
AXIOM_TOKEN=

# Buu 3D asset generation
BUU_API_KEY=
BUU_API_URL=https://dev.api.buu.fun
NEXT_PUBLIC_BUU_API_URL=https://dev.api.buu.fun

# CORS (comma-separated origins, defaults to * if unset)
ALLOWED_ORIGINS=https://atomic.fun,https://www.atomic.fun
