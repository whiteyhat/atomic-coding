# Local development configuration
# Copy to .env.development.local and fill in your values:
#   cp .env.development.example .env.development.local

# ── Hybrid mode (required for `npm run dev:env:hybrid`) ──
DEV_SUPABASE_URL=
DEV_SUPABASE_ANON_KEY=
DEV_SUPABASE_SERVICE_ROLE_KEY=

# ── Shared (required for both modes) ──
OPENROUTER_API_KEY=

# ── Optional ──
# NEXT_PUBLIC_PRIVY_APP_ID=
# PRIVY_APP_SECRET=
# BUU_API_KEY=
# SUPABASE_ACCESS_TOKEN=
# MASTRA_SERVER_URL=http://127.0.0.1:4500
# DEV_AUTH_BYPASS=true
# DEV_AUTH_BYPASS_USER_ID=did:dev:local-user
# DEV_AUTH_BYPASS_TOKEN=dev-bypass
